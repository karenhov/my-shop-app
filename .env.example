# DATABASE_URL: PostgreSQL connection string (Supabase-ի կամ այл DB-ի)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# GEMINI_API_KEY: Server-side only — client bundle-ի մեջ ՉՊԵՏՔ Է հայտնվի:
# Render-ում ավелацрек Environment Variables-ում (ոч VITE_ prefix-ов):
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Cloudinary (cart image sharing-ի хамар)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
