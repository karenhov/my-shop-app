        "html-to-image": "^1.11.13",
        "lucide-react": "^0.546.0",
        "motion": "^12.23.24",
        "pg": "^8.19.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-markdown": "^10.1.0",
        "tsx": "^4.21.0",
        "twilio": "^5.13.1",
        "vite": "^6.2.0"
    },
